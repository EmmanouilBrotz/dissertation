<group name="local,authentication,ssh,">

  <!-- Rule 100001: SSH successful login -->
  <rule id="100001" level="3">
    <if_sid>5501</if_sid>
    <description>SSH: Successful authentication</description>
    <group>authentication_success,pci_dss_10.2.5,</group>
  </rule>

  <!-- Rule 100002: SSH lateral movement - Jump host to Target VM -->
  <rule id="100002" level="10">
    <if_sid>100001</if_sid>
    <hostname>target-vm</hostname>
    <description>SSH: LATERAL MOVEMENT - Login to target-vm detected</description>
    <mitre>
      <id>T1021.004</id>
    </mitre>
    <group>lateral_movement,attack,</group>
  </rule>

  <!-- Rule 100003: Multiple SSH connections in short time (lateral movement pattern) -->
  <rule id="100003" level="12" frequency="3" timeframe="60">
    <if_matched_sid>100002</if_matched_sid>
    <description>SSH: CRITICAL - Rapid lateral movement detected (3 logins in 60s)</description>
    <mitre>
      <id>T1021.004</id>
    </mitre>
    <group>lateral_movement,attack,</group>
  </rule>

  <!-- Rule 100004: SSH failed login attempt -->
  <rule id="100004" level="5">
    <if_sid>5503,5504,5551</if_sid>
    <description>SSH: Failed authentication attempt</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <!-- Rule 100005: SSH brute force - Multiple failed attempts -->
  <rule id="100005" level="10" frequency="5" timeframe="120">
    <if_matched_sid>100004</if_matched_sid>
    <same_source_ip />
    <description>SSH: BRUTE FORCE ATTACK - 5+ failed attempts from same IP in 2 minutes</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,brute_force,pci_dss_11.4,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <!-- Rule 100006: SSH brute force - CRITICAL (10+ attempts) -->
  <rule id="100006" level="12" frequency="10" timeframe="180">
    <if_matched_sid>100004</if_matched_sid>
    <same_source_ip />
    <description>SSH: CRITICAL BRUTE FORCE - 10+ failed attempts, auto-blocking IP</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,brute_force,attack,</group>
  </rule>

  <!-- Rule 100007: Root login via SSH -->
  <rule id="100007" level="8">
    <if_sid>5501</if_sid>
    <user>root</user>
    <description>SSH: Direct root login detected (security violation)</description>
    <group>authentication_success,policy_violation,</group>
  </rule>

  <!-- Rule 100008: SSH login from new/unusual location -->
  <rule id="100008" level="7">
    <if_sid>5501</if_sid>
    <description>SSH: Login from new source IP (baseline anomaly)</description>
    <group>authentication_success,anomaly,</group>
  </rule>

</group>

<group name="local,privilege_escalation,">

